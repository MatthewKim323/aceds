# ============================================================================
# ACE environment template. Copy to .env and fill in real values.
# Any file matching `.env*` except `.env.example` is gitignored.
# ============================================================================

# ---- Data pipeline (Python scripts in data_pipeline/) -----------------------
UCSB_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- FastAPI backend (backend/) --------------------------------------------
# Same SUPABASE_URL as above; the backend only uses service role for privileged ops
ACE_ENV=development
ACE_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
ACE_MODEL_DIR=./app/ml/artifacts
ACE_LOG_LEVEL=INFO

# ---- Frontend (frontend/) --------------------------------------------------
# These are read at build time by Vite — must be prefixed with VITE_
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE=http://localhost:8000
VITE_ANTHROPIC_API_KEY=

# Notes:
# - VITE_ANTHROPIC_API_KEY is only used for client-side transcript parsing in
#   onboarding. Rotate it if the repo ever goes public; consider proxying via
#   the FastAPI backend before launch.
# - SUPABASE_SERVICE_ROLE_KEY has god mode. Never expose to the client. Only
#   data_pipeline/ scripts and the FastAPI backend use it.
